<UserControl x:Class="Wpf.Example.Controls.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Wpf.Example.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="24">
		<Grid.RowDefinitions>
			<!-- Header mit Statistik-Badges -->
			<RowDefinition Height="Auto"/>
			<!-- Hauptbereich: Die Buchungsübersicht -->
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- ============================================================================== -->
		<!-- HEADER & KENNZAHLEN (KPIs) -->
		<!-- ============================================================================== -->
		<Grid Grid.Row="0" Margin="0,0,0,24">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Titel -->
			<StackPanel Grid.Column="0" VerticalAlignment="Center">
				<TextBlock Text="Mein Buchungs-Dashboard" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
				<TextBlock Text="Hier siehst du deine reservierten Arbeitsplätze für die kommenden Wochen." FontSize="13" Foreground="#6B7280" Margin="0,2,0,0"/>
			</StackPanel>

			<!-- Kleine Statistik-Karten rechts im Header -->
			<StackPanel Grid.Column="1" Orientation="Horizontal">
				<Border Background="White" CornerRadius="8" Padding="16,10" Margin="0,0,12,0" BorderBrush="#E5E7EB" BorderThickness="1">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="📅" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
						<StackPanel>
							<TextBlock Text="Aktive Buchungen" FontSize="11" Foreground="#6B7280" FontWeight="Medium"/>
							<TextBlock Text="{Binding TotalBookingsCount, FallbackValue=5}" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
						</StackPanel>
					</StackPanel>
				</Border>
				<Border Background="#EFF6FF" CornerRadius="8" Padding="16,10" BorderBrush="#BFDBFE" BorderThickness="1">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="🏢" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
						<StackPanel>
							<TextBlock Text="Nächster Einsatztag" FontSize="11" Foreground="#1D4ED8" FontWeight="Medium"/>
							<TextBlock Text="{Binding NextBookingDateString, FallbackValue='Morgen'}" FontSize="16" FontWeight="Bold" Foreground="#1E40AF"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</StackPanel>
		</Grid>
		<Grid Grid.Row="1">
			<!-- ScrollViewer, falls die Liste lang wird -->
			<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

				<!-- ItemsControl rendert die Karten flexibel untereinander -->
				<ItemsControl ItemsSource="{Binding UpcomingBookings}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<!-- Die "Card" für eine Buchung -->
							<Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,12" Padding="16">
								<Border.Style>
									<Style TargetType="Border">
										<Style.Triggers>
											<!-- Subtiler Hover-Effekt für die Karte -->
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="BorderBrush" Value="#3B82F6"/>
												<Setter Property="Effect">
													<Setter.Value>
														<DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
													</Setter.Value>
												</Setter>
											</Trigger>
										</Style.Triggers>
									</Style>
								</Border.Style>

								<Grid>
									<Grid.ColumnDefinitions>
										<!-- Spalte 1: Datum & Wochentag -->
										<ColumnDefinition Width="140"/>
										<!-- Spalte 2: Vertikaler Trenner -->
										<ColumnDefinition Width="Auto"/>
										<!-- Spalte 3: Tisch & Raumdetails -->
										<ColumnDefinition Width="*"/>
										<!-- Spalte 4: Inventar-Tags -->
										<ColumnDefinition Width="Auto"/>
										<!-- Spalte 5: Stornieren-Button -->
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<!-- DATUM & WOCHENTAG -->
									<StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="4,0,0,0">
										<!-- z.B. "Mittwoch" -->
										<TextBlock Text="{Binding Date, StringFormat=\{0:dddd\}}" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563"/>
										<!-- z.B. "01. Juli 2026" -->
										<TextBlock Text="{Binding Date, StringFormat=\{0:dd. MMMM\}}" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,2,0,0"/>
									</StackPanel>

									<!-- DEZENTER TRENNER -->
									<Rectangle Grid.Column="1" Width="1" Fill="#E5E7EB" Margin="16,4" Stretch="Fill"/>

									<!-- TISCH & RAUM DETAILS -->
									<StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
										<StackPanel Orientation="Horizontal">
											<!-- Badge für den Raum -->
											<Border Background="#F3F4F6" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
												<TextBlock Text="{Binding Desk.Room.Name}" FontSize="11" FontWeight="Medium" Foreground="#374151"/>
											</Border>
											<!-- Zusatzinfo wie "Höhenverstellbar" -->
											<TextBlock Text="{Binding Desk.Remarks}" FontSize="12" Foreground="#9CA3AF" VerticalAlignment="Center" FontStyle="Italic"	/>
										</StackPanel>

										<!-- Großer Name des Schreibtischs -->
										<TextBlock Text="{Binding Desk.Name}" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,4,0,0"/>
									</StackPanel>

									<!-- INVENTAR BADGES (Welche Hardware erwartet mich?) -->
									<ItemsControl Grid.Column="3" ItemsSource="{Binding Desk.Inventory}" VerticalAlignment="Center" Margin="16,0">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Orientation="Horizontal"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<!-- Kleines graues Icon-Badge pro Inventargegenstand -->
												<Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="0,0,6,0">
													<StackPanel Orientation="Horizontal">
														<TextBlock Text="🛠️" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding Name}" FontSize="11" Foreground="#4B5563" VerticalAlignment="Center"/>
													</StackPanel>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

									<!-- AKTIONEN (Stornieren) -->
									<Button Grid.Column="4" 
                                            Command="{Binding DataContext.CancelBookingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Stornieren" 
                                            Background="Transparent" 
                                            BorderBrush="#FCA5A5" 
                                            Foreground="#DC2626" 
                                            Padding="12,6" 
                                            VerticalAlignment="Center">
										<Button.Resources>
											<Style TargetType="Border">
												<Setter Property="CornerRadius" Value="6"/>
											</Style>
										</Button.Resources>
										<Button.Style>
											<Style TargetType="Button">
												<Style.Triggers>
													<!-- Hover-Effekt: Wird dezent rot beim Drüberfahren -->
													<Trigger Property="IsMouseOver" Value="True">
														<Setter Property="Background" Value="#FEF2F2"/>
													</Trigger>
												</Style.Triggers>
											</Style>
										</Button.Style>
									</Button>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</ScrollViewer>
		</Grid>
	</Grid>
</UserControl>
