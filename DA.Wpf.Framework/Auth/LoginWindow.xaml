<Window x:Class="DA.Wpf.Framework.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DA.Wpf.Framework.Auth"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800">

	<Grid Margin="32,24,32,32">
		<Grid.RowDefinitions>
			<!-- Logo / Branding -->
			<RowDefinition Height="Auto"/>
			<!-- Eingabefelder -->
			<RowDefinition Height="*"/>
			<!-- Button -->
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- ============================================================================== -->
		<!-- BRANDING / HEADER -->
		<!-- ============================================================================== -->
		<StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,12,0,28">
			<!-- Ein schlichtes, modernes Icon-Substitut -->
			<Border Width="48" Height="48" Background="#3B82F6" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,12">
				<TextBlock Text="D" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
			</Border>
			<TextBlock Text="Willkommen zurück" FontSize="20" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center"/>
			<TextBlock Text="Melde dich an, um deinen Platz zu buchen." FontSize="12" Foreground="#6B7280" Margin="0,4,0,0" HorizontalAlignment="Center"/>
		</StackPanel>

		<!-- ============================================================================== -->
		<!-- EINGABEFORMULAR -->
		<!-- ============================================================================== -->
		<StackPanel Grid.Row="1" VerticalAlignment="Top">

			<!-- BENUTZERNAME -->
			<TextBlock Text="Benutzername" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,6"/>
			<TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Height="38" Padding="10,0" VerticalContentAlignment="Center"
                     Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,18">
				<TextBox.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="6"/>
					</Style>
				</TextBox.Resources>
			</TextBox>

			<!-- PASSWORT -->
			<TextBlock Text="Passwort" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,6"/>
			<!-- Wichtig: Eine echte PasswordBox für die Sicherheit -->
			<PasswordBox x:Name="TxtPassword" 
                         Height="38" Padding="10,0" VerticalContentAlignment="Center"
                         Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,8">
				<PasswordBox.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="6"/>
					</Style>
					</PasswordBox.Resources>
			</PasswordBox>

			<!-- OPTIONAL: Hier ist Platz für eine Fehlermeldung, falls der Login fehlschlägt 
			<TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" 
                       Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"/>-->
		</StackPanel>

		<!-- ============================================================================== -->
		<!-- ACTIONS (LOGIN BUTTON) -->
		<!-- ============================================================================== -->
		<Button Grid.Row="2" IsDefault="True"
                Content="Anmelden" 
                Command="{Binding LoginCommand}"
                CommandParameter="{Binding ElementName=TxtPassword}"
                Height="40" Background="#3B82F6" Foreground="White" FontSize="14" FontWeight="SemiBold" BorderThickness="0">
			<Button.Resources>
				<Style TargetType="Border">
					<Setter Property="CornerRadius" Value="6"/>
				</Style>
			</Button.Resources>
			<Button.Style>
				<Style TargetType="Button">
					<Style.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter Property="Background" Value="#2563EB"/>
						</Trigger>
						<Trigger Property="IsEnabled" Value="False">
							<Setter Property="Background" Value="#9CA3AF"/>
						</Trigger>
					</Style.Triggers>
				</Style>
			</Button.Style>
		</Button>
	</Grid>
</Window>
